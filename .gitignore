# ── Generated / large data artifacts (regenerable from the pipeline) ─
# Big embedding matrices — keep only the small one the app needs at runtime.
*.npy
!data/processed/kb_embeddings.npy

# Standalone Plotly HTML exports — superseded by the app + dashboard.
data/processed/*.html

# Intermediate pipeline byproducts (regenerated by src/ scripts).
data/processed/kb_clusters.csv
data/processed/kb_topic_info.csv
data/processed/tumblr_mapped.csv
data/processed/tumblr_temporal.csv
data/processed/meta_clean.csv
data/processed/meta_with_topics.csv
