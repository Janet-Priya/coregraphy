data/processed/review_cluster_mapping.csv
data/processed/temporal_analysis.csv
data/processed/topic_info.csv

# Orphaned / dead.
data/raw/aesthetics_kb_clean.csv

# Large raw review dump (~18 MB, not needed by the app).
# Reviewers who want to reproduce the review analysis can `git add -f` this.
data/raw/fashion_reviews.csv

